-- Cached non-Dorn base rows so MCM can hide/restore them.
local saved_base_stats = {}

local function is_dorn_stat_def(gr)
	return gr and gr.name and string.find(gr.name, "ui_dorn_wpn_", 1, true) == 1
end

local function cache_base_stat(weapon_stats, key)
	local cur = weapon_stats[key]
	if cur and not is_dorn_stat_def(cur) then
		saved_base_stats[key] = cur
	end
end

local function set_base_stat(weapon_stats, key, enabled)
	cache_base_stat(weapon_stats, key)
	if enabled then
		if saved_base_stats[key] then
			weapon_stats[key] = saved_base_stats[key]
		end
	else
		weapon_stats[key] = nil
	end
end

local function make_dorn_row(index, name, icon, prop)
	return {
		index = index,
		typ = "float",
		name = name,
		icon_p = icon,
		icon_n = "",
		track = false,
		magnitude = 1,
		unit = "",
		compare = false,
		sign = false,
		show_always = true,
		-- Functors must live on this script module (zz_dorn_weapon_tooltip_main.*);
		-- X-Ray resolves _G[file][func], not nested table fields on another script.
		value_functor = { "zz_dorn_weapon_tooltip_main", prop },
	}
end

-- Highest sort index among stock/Momopate weapon rows (excludes Dorn keys).
local function max_non_dorn_weapon_index(weapon_stats)
	local max_i = 0
	for key, def in pairs(weapon_stats) do
		if def and type(def) == "table" and def.index
			and key ~= "damage"
			and string.find(key, "dorn_", 1, true) ~= 1
		then
			if def.index > max_i then
				max_i = def.index
			end
		end
	end
	return max_i
end

local function placement_indices(weapon_stats)
	if CONFIG.stat_row_placement == "after" then
		-- Block after Accuracy…Recoil Control (and any other non-Dorn rows).
		local base = max_non_dorn_weapon_index(weapon_stats)
		return {
			hit_power = base + 1,
			stalker_damage = base + 2,
			mutant_damage = base + 3,
			base_spread = base + 4,
			movement_spread = base + 5,
			bullet_drop = base + 6,
			weapon_wear = base + 7,
			burst_control = base + 8,
		}
	end
	-- Inline: Hit Power fills ADV's unused index 3 (between Handling and Fire Rate).
	return {
		hit_power = 3,
		stalker_damage = 3.25,
		mutant_damage = 3.5,
		base_spread = EXTRA_STAT_INDEX_INLINE.base_spread,
		movement_spread = EXTRA_STAT_INDEX_INLINE.movement_spread,
		bullet_drop = EXTRA_STAT_INDEX_INLINE.bullet_drop,
		weapon_wear = EXTRA_STAT_INDEX_INLINE.weapon_wear,
		burst_control = EXTRA_STAT_INDEX_INLINE.burst_control,
	}
end

local function apply_enhanced_weapon_stats()
	if not utils_ui or not utils_ui.stats_table then
		return
	end

	local weapon_stats = utils_ui.stats_table["weapon"]
	if not weapon_stats then
		return
	end

	set_base_stat(weapon_stats, "accuracy", CONFIG.show_accuracy)
	set_base_stat(weapon_stats, "handling", CONFIG.show_handling)
	set_base_stat(weapon_stats, "reliability", CONFIG.show_reliability)
	set_base_stat(weapon_stats, "recoil", CONFIG.show_recoil)
	set_base_stat(weapon_stats, "speed", CONFIG.show_muzzle_velocity)

	local idx = placement_indices(weapon_stats)

	HIT_POWER_STAT.index = idx.hit_power
	STALKER_DAMAGE_STAT.index = idx.stalker_damage
	RAW_AMMO_DAMAGE_STAT.index = idx.mutant_damage

	cache_base_stat(weapon_stats, "damage")
	if CONFIG.show_hit_power then
		weapon_stats["damage"] = HIT_POWER_STAT
	else
		weapon_stats["damage"] = saved_base_stats["damage"]
	end

	if CONFIG.show_stalker_damage then
		weapon_stats["dorn_stalker_damage"] = STALKER_DAMAGE_STAT
	else
		weapon_stats["dorn_stalker_damage"] = nil
	end
	if CONFIG.show_mutant_damage then
		weapon_stats["dorn_ammo_damage"] = RAW_AMMO_DAMAGE_STAT
	else
		weapon_stats["dorn_ammo_damage"] = nil
	end

	local N = (dorn_weapon_tooltip_stats and dorn_weapon_tooltip_stats.NAME) or EXTRA_STAT_NAME
	weapon_stats["dorn_base_spread"] = CONFIG.show_base_spread
		and make_dorn_row(idx.base_spread, N.base_spread, "ui_wp_prop_tochnost", "prop_base_spread")
		or nil
	weapon_stats["dorn_movement_spread"] = CONFIG.show_movement_spread
		and make_dorn_row(idx.movement_spread, N.movement_spread, "ui_wp_prop_ergonomics", "prop_movement_spread")
		or nil
	weapon_stats["dorn_bullet_drop"] = CONFIG.show_bullet_drop
		and make_dorn_row(idx.bullet_drop, N.bullet_drop, "ui_wp_propery_06", "prop_bullet_drop")
		or nil
	weapon_stats["dorn_weapon_wear"] = CONFIG.show_weapon_wear
		and make_dorn_row(idx.weapon_wear, N.weapon_wear, "ui_wp_propery_08", "prop_weapon_wear")
		or nil
	weapon_stats["dorn_burst_control"] = CONFIG.show_burst_control
		and make_dorn_row(idx.burst_control, N.burst_control, "ui_wp_propery_03", "prop_burst_control")
		or nil
end

-- Legacy single toggle (show_enhanced_weapon_stats) seeds both new keys when absent.
local function read_legacy_enhanced_default()
	if not DORN or not DORN.mcm then
		return true
	end

	if DORN.mcm.get(MOD_ID, "main/show_enhanced_weapon_stats") ~= nil then
		return DORN.mcm.bool(MOD_ID, "main/show_enhanced_weapon_stats", true)
	end

	local mode = DORN.mcm.string(MOD_ID, "main/damage_stat", nil)
	if mode == "raw_hit_power" then
		mode = "hit_power"
	elseif mode == "ammo_torso" then
		mode = "damage"
	end
	if mode == "off" then
		return false
	end
	if mode == "hit_power" or mode == "damage" then
		return true
	end

	if DORN.mcm.get(MOD_ID, "main/show_damage_stat") ~= nil then
		return DORN.mcm.bool(MOD_ID, "main/show_damage_stat", false)
	end

	return true
end

local function read_show_new_weapon_stats_default()
	if not DORN or not DORN.mcm then
		return true
	end
	if DORN.mcm.get(MOD_ID, "main/show_new_weapon_stats") ~= nil then
		return DORN.mcm.bool(MOD_ID, "main/show_new_weapon_stats", true)
	end
	return read_legacy_enhanced_default()
end

local function read_new_stat_flag(key)
	if not DORN or not DORN.mcm then
		return true
	end
	if DORN.mcm.get(MOD_ID, "main/" .. key) ~= nil then
		return DORN.mcm.bool(MOD_ID, "main/" .. key, true)
	end
	return read_show_new_weapon_stats_default()
end

-- Legacy master / per-append keys seed the new child-row toggles when absent.
local function read_extra_stat_default()
	if not DORN or not DORN.mcm then
		return true
	end
	if DORN.mcm.get(MOD_ID, "main/show_appended_weapon_stats") ~= nil then
		return DORN.mcm.bool(MOD_ID, "main/show_appended_weapon_stats", true)
	end
	return read_legacy_enhanced_default()
end

local EXTRA_STAT_LEGACY = {
	show_base_spread = "show_append_accuracy",
	show_movement_spread = "show_append_handling",
	show_weapon_wear = "show_append_reliability",
	show_burst_control = "show_append_recoil",
	show_bullet_drop = "show_append_muzzle_velocity",
}

local function read_extra_stat_flag(key)
	if not DORN or not DORN.mcm then
		return true
	end
	if DORN.mcm.get(MOD_ID, "main/" .. key) ~= nil then
		return DORN.mcm.bool(MOD_ID, "main/" .. key, true)
	end
	local legacy = EXTRA_STAT_LEGACY[key]
	if legacy and DORN.mcm.get(MOD_ID, "main/" .. legacy) ~= nil then
		return DORN.mcm.bool(MOD_ID, "main/" .. legacy, true)
	end
	return read_extra_stat_default()
end

local function read_base_stat_flag(key)
	if not DORN or not DORN.mcm then
		return true
	end
	if DORN.mcm.get(MOD_ID, "main/" .. key) ~= nil then
		return DORN.mcm.bool(MOD_ID, "main/" .. key, true)
	end
	return true
end

local logged_once = {}

local function log(msg)
	if not (DORN and DORN.dbg) then
		return
	end
	if CONFIG.debug_log then
		DORN.dbg.log(MOD_ID, tostring(msg))
	end
end

-- Log each key at most once per session (debug_log only). Global/bootstrap events
-- use plain keys; per-item paths use log_item_once(reason, sec, msg) instead.
local function log_once(key, msg)
	if logged_once[key] then
		return
	end
	if not (DORN and DORN.dbg) or not CONFIG.debug_log then
		return
	end
	logged_once[key] = true
	log(msg)
end

-- Per weapon section: dedupe repeated hovers on the same item, not across items.
local function log_item_once(reason, sec, msg)
	log_once(reason .. ":" .. tostring(sec), msg)
end

-- UIInfoItem:Update caches by item id/section and early-returns for the same
-- item, so after an MCM change we must clear that cache or stat rows won't
-- rebuild until a different item is hovered.
local tracked_infos = setmetatable({}, { __mode = "k" })

local function on_option_change()
	-- All MCM/palette work is optional - the per-ammo breakdown must keep working
	-- even if DORN common failed to load, so nothing here is allowed to hard-fail.
	local prev_debug = CONFIG.debug_log
	if DORN and DORN.mcm then
		CONFIG.show_damage_table = DORN.mcm.bool(MOD_ID, "main/show_damage_table", true)
		CONFIG.show_hit_power = read_new_stat_flag("show_hit_power")
		CONFIG.show_stalker_damage = read_new_stat_flag("show_stalker_damage")
		CONFIG.show_mutant_damage = read_new_stat_flag("show_mutant_damage")
		CONFIG.show_accuracy = read_base_stat_flag("show_accuracy")
		CONFIG.show_handling = read_base_stat_flag("show_handling")
		CONFIG.show_reliability = read_base_stat_flag("show_reliability")
		CONFIG.show_recoil = read_base_stat_flag("show_recoil")
		CONFIG.show_muzzle_velocity = read_base_stat_flag("show_muzzle_velocity")
		CONFIG.show_base_spread = read_extra_stat_flag("show_base_spread")
		CONFIG.show_movement_spread = read_extra_stat_flag("show_movement_spread")
		CONFIG.show_weapon_wear = read_extra_stat_flag("show_weapon_wear")
		CONFIG.show_burst_control = read_extra_stat_flag("show_burst_control")
		CONFIG.show_bullet_drop = read_extra_stat_flag("show_bullet_drop")
		-- "raw" = bone armor floats; "names" = short class labels.
		-- Legacy MCM values: "npc" -> raw, "brc" -> names.
		local headers = DORN.mcm.string(MOD_ID, "main/column_headers", "names")
		if headers == "raw" or headers == "npc" then
			CONFIG.column_headers = "raw"
		else
			CONFIG.column_headers = "names"
		end
		local order = DORN.mcm.string(MOD_ID, "main/ammo_order", "default")
		if order == "ap" then
			CONFIG.ammo_order = "ap"
		elseif order == "damage" then
			CONFIG.ammo_order = "damage"
		else
			CONFIG.ammo_order = "default"
		end
		local place = DORN.mcm.string(MOD_ID, "main/stat_row_placement", "inline")
		if place == "after" then
			CONFIG.stat_row_placement = "after"
		else
			CONFIG.stat_row_placement = "inline"
		end
		CONFIG.calc_range_m = clamp(DORN.mcm.number(MOD_ID, "main/calc_range", 20), 0, 200)
		local drop_range = clamp(DORN.mcm.number(MOD_ID, "main/drop_range", 200), 100, 2000)
		if dorn_weapon_tooltip_stats and dorn_weapon_tooltip_stats.set_drop_range then
			dorn_weapon_tooltip_stats.set_drop_range(drop_range)
		end
		CONFIG.use_condition_table = DORN.mcm.bool(MOD_ID, "main/use_condition_table", false)
		CONFIG.use_condition_stats = DORN.mcm.bool(MOD_ID, "main/use_condition_stats", false)
		CONFIG.apply_silencer = DORN.mcm.bool(MOD_ID, "main/apply_silencer", true)
		CONFIG.debug_log = DORN.mcm.bool(MOD_ID, "development/debug_log", false)
		CONFIG.rangefinder = DORN.mcm.bool(MOD_ID, "development/rangefinder", false)
	end

	if CONFIG.debug_log and not prev_debug then
		logged_once = {}
	end

	if DORN and DORN.dbg and DORN.dbg.set_enabled then
		DORN.dbg.set_enabled(MOD_ID, CONFIG.rangefinder)
	end

	refresh_enhanced_stat_labels()
	apply_enhanced_weapon_stats()
	for info in pairs(tracked_infos) do
		info.id = nil
		info.section = nil
	end

	log_once("config", string.format(
		"config: table=%s hit=%s mutant=%s base=%s/%s/%s/%s/%s extra=%s/%s/%s/%s/%s place=%s headers=%s order=%s range=%s cond=%s/%s sil=%s",
		tostring(CONFIG.show_damage_table), tostring(CONFIG.show_hit_power),
		tostring(CONFIG.show_mutant_damage),
		tostring(CONFIG.show_accuracy), tostring(CONFIG.show_handling),
		tostring(CONFIG.show_reliability), tostring(CONFIG.show_recoil),
		tostring(CONFIG.show_muzzle_velocity),
		tostring(CONFIG.show_base_spread), tostring(CONFIG.show_movement_spread),
		tostring(CONFIG.show_weapon_wear), tostring(CONFIG.show_burst_control),
		tostring(CONFIG.show_bullet_drop), tostring(CONFIG.stat_row_placement),
		tostring(CONFIG.column_headers), tostring(CONFIG.ammo_order),
		tostring(CONFIG.calc_range_m), tostring(CONFIG.use_condition_table),
		tostring(CONFIG.use_condition_stats), tostring(CONFIG.apply_silencer)))
end

local function first_number(str)
	if not str then
		return 0
	end
	return tonumber(str:match("[%-%d%.]+")) or 0
end

local function gun_hit_power(obj, sec)
	if obj and utils_item and utils_item.get_wpn_param then
		return utils_item.get_wpn_param(obj, sec, "hit_power", 0) or 0
	end
	return first_number(SYS_GetParam(0, sec, "hit_power", "0"))
end

local function is_degraded_ammo(sec)
	return string.find(sec, "bad", 1, true) ~= nil
end

function prop_hit_power(obj, sec)
	return gun_hit_power(obj, sec)
end

-- Sentinel so the stat row shows; display text is set in apply_custom_stat_display.
function prop_raw_ammo_damage_slash_flag(obj, sec)
	if format_raw_ammo_damage_slash(obj, sec) then
		return 1
	end
end

function prop_stalker_ammo_damage_slash_flag(obj, sec)
	if format_stalker_ammo_damage_slash(obj, sec) then
		return 1
	end
end

-- Sentinels for appended stat rows (real text applied in apply_custom_stat_display).
function prop_base_spread(obj, sec)
	local S = dorn_weapon_tooltip_stats
	if S and S.text_base_spread and S.text_base_spread(obj, sec) then
		return 1
	end
end

function prop_movement_spread(obj, sec)
	local S = dorn_weapon_tooltip_stats
	if S and S.text_movement_spread and S.text_movement_spread(obj, sec) then
		return 1
	end
end

function prop_weapon_wear(obj, sec)
	local S = dorn_weapon_tooltip_stats
	if S and S.text_weapon_wear and S.text_weapon_wear(obj, sec) then
		return 1
	end
end

function prop_burst_control(obj, sec)
	local S = dorn_weapon_tooltip_stats
	if S and S.text_burst_control and S.text_burst_control(obj, sec) then
		return 1
	end
end

function prop_bullet_drop(obj, sec)
	local S = dorn_weapon_tooltip_stats
	if S and S.text_bullet_drop and S.text_bullet_drop(obj, sec) then
		return 1
	end
end

function scale_hit_power_display(obj, sec, base_file, base_func, param)
	local base = _G[base_file][base_func](obj, sec, param)
	return math.floor(base * DAMAGE_SCALE)
end

local function dist_atten(air_res, dist)
	return 1 + dist / 200 * air_res * 0.5 / (1 - air_res + 0.1)
end

local function calc_range()
	local d = tonumber(CONFIG.calc_range_m)
	if not d then
		return REF_DIST_M
	end
	return clamp(d, 0, 200)
end

-- Barrel part condition 0..1. Missing parts data => 1.0.
local function raw_barrel_condition(obj)
	if not obj then
		return 1
	end
	local ok, parts = pcall(function()
		return se_load_var(obj:id(), obj:name(), "parts")
	end)
	if not ok or type(parts) ~= "table" then
		return 1
	end
	for k, v in pairs(parts) do
		if type(k) == "string" and string.find(k, "barrel") then
			local n = tonumber(v)
			if n then
				return clamp(n / 100, 0, 1)
			end
		end
	end
	return 1
end

-- CQC corrected barrel mult (same curve for stalker and mutant). Cap at 1.
-- When use_condition is false, always 1.0 (100%).
local function barrel_mult(obj, use_condition, kind)
	if not use_condition then
		return 1
	end
	local bc = raw_barrel_condition(obj)
	local corrected = (130 - (1.12 * bc)) * (bc * 1.12) / 100
	if corrected > 1 then
		return 1
	end
	return corrected
end

-- GAMMA character-creation difficulty (1-4). Falls back to engine gd index.
local function difficulty_mult()
	local ok, state = pcall(function()
		return alife_storage_manager.get_state()
	end)
	if ok and state and type(state.diff_game) == "table" then
		local t = tonumber(state.diff_game.type)
		if t and DIFFICULTY_MULT[t] then
			return DIFFICULTY_MULT[t]
		end
	end
	if level and level.get_game_difficulty then
		local gd = level.get_game_difficulty()
		-- Engine is 0-based; GAMMA diff_game type is 1-based.
		local t = (tonumber(gd) or 0) + 1
		if DIFFICULTY_MULT[t] then
			return DIFFICULTY_MULT[t]
		end
	end
	return 1.0
end

-- Display AP (k_ap x 1000) needed for CQC combat_ap to first penetrate 0.650 torso armor.
local function ap_pen_display_max(silencer)
	local dist_mult = dist_atten(AP_COLOR_REF_AIR, calc_range())
	local k_ap_ltx = AP_COLOR_ARMOR * dist_mult
		/ (K_AP_COMBAT_SCALE * AP_COLOR_AP_SCALE * AP_TAIL * difficulty_mult() * (silencer or 1))
	return math.max(math.ceil(k_ap_ltx * AP_SCALE), 1)
end

local function ap_display_color(ap, silencer)
	local hi = ap_pen_display_max(silencer)
	local t = clamp((tonumber(ap) or 0) / hi, 0, 1)
	-- grey (175,175,175) → orange (255,150,0); matches TYPE_RGB.orange.
	return GetARGB(255,
		math.floor(lerp(175, 255, t)),
		math.floor(lerp(175, 150, t)),
		math.floor(lerp(175, 0, t)))
end

-- CQC NPC ammo_mult (only 7.62x25 P is special).
local function npc_ammo_mult(ammo_sec)
	if ammo_sec == "ammo_7.62x25_p" or ammo_sec == "ammo_7.62x25_p_bad" then
		return 1.75
	end
	return 1.0
end

-- CQC silencer_boost: 1.07 if attached silencer or integrated suppressor parent.
local function silencer_mult(obj, sec)
	if not CONFIG.apply_silencer then
		return 1
	end
	if obj then
		local ok, has = pcall(function()
			return obj:weapon_is_silencer()
		end)
		if ok and has then
			return SILENCER_BOOST
		end
	end
	local parent = sec and (ini_sys:r_string_ex(sec, "parent_section") or sec) or nil
	if parent and INTEGRATED_SILENCER[parent] then
		return SILENCER_BOOST
	end
	return 1
end

-- CQC: (k_ap x10) x ap_scale x barrel / range_factor x 0.80 x difficulty x silencer.
local function combat_ap(k_ap_ltx, air_res, dist, ap_scale, barrel, silencer)
	return (k_ap_ltx * K_AP_COMBAT_SCALE)
		* ap_scale * (barrel or 1)
		/ dist_atten(air_res, dist)
		* AP_TAIL
		* difficulty_mult()
		* (silencer or 1)
end

-- CQC NPC power, plus difficulty, optional barrel, NPC ammo_mult, and silencer.
local function base_power(hit_power, k_hit, air_res, dist, bone_mult, ap_scale, pellet_mult, barrel, ammo_sec, silencer)
	return hit_power / dist_atten(air_res, dist)
		* k_hit * bone_mult * ap_scale * BALLISTIC_BONUS * pellet_mult
		* difficulty_mult() * (barrel or 1)
		* npc_ammo_mult(ammo_sec)
		* (silencer or 1)
end

local function effective_dmg(hit_power, k_hit, k_ap_ltx, air_res, armor, ap_scale, hit_frac, bone_mult, dist, pellet_mult, barrel, ammo_sec, silencer)
	local ap = combat_ap(k_ap_ltx, air_res, dist, ap_scale, barrel, silencer)
	local power = base_power(hit_power, k_hit, air_res, dist, bone_mult, ap_scale, pellet_mult, barrel, ammo_sec, silencer)
	-- Armor 0 (bare head): always full power; never apply chip hit_frac.
	local penetrated = (armor <= 0) or (ap >= armor)
	local dmg = penetrated and power or (power * hit_frac)
	return {
		dmg = dmg * DAMAGE_SCALE,
		penetrated = penetrated,
	}
end

local function fmt_tier_cells(vals, num_tiers)
	local out = {}
	for i = 1, num_tiers do
		local cell = vals[i]
		if cell then
			out[i] = {
				text = tostring(math.floor(cell.dmg + 0.5)),
				dmg = cell.dmg,
				penetrated = cell.penetrated,
			}
		end
	end
	return out
end

-- Highest damage in a table section across every ammo row (torso or head).
local function section_dmg_max(rows, section)
	local hi = 1
	local n = (section == "head") and NUM_HEAD_TIERS or NUM_TORSO_TIERS
	for _, row in ipairs(rows) do
		local cells = section == "torso" and row.torso or row.head
		for i = 1, n do
			local c = cells[i]
			if c and c.dmg > hi then
				hi = c.dmg
			end
		end
	end
	return hi
end

local function calc_tier_damages(hit_power, k_hit, k_ap_ltx, air_res, tiers, headshot, dist, pellet_mult, barrel, ammo_sec, silencer)
	local bone_mult = headshot and BONE_DMG_HEAD or BONE_DMG_TORSO
	local out = {}
	for i, tier in ipairs(tiers) do
		out[i] = effective_dmg(
			hit_power, k_hit, k_ap_ltx, air_res, tier.armor,
			tier.ap_scale, tier.hit_frac, bone_mult,
			dist, pellet_mult, barrel, ammo_sec, silencer
		)
	end
	return out
end

-- Unique ammo rounds for a weapon (same order as the damage table).
-- ammo_order "damage": dmg desc, then AP asc. "ap": AP desc, then label.
-- "default": leave utils_item.get_ammo order (matches tooltip ammo icons).
local function collect_sorted_ammo_rounds(obj, sec, max_count)
	local ammo_class = SYS_GetParam(0, sec, "ammo_class", "")
	if not ammo_class or ammo_class == "" then
		log_item_once("no_ammo_class", sec, string.format("%s: no ammo_class", sec))
		return nil
	end

	local ammo_list = utils_item.get_ammo(sec, obj and obj:id() or nil)
	if not ammo_list or not ammo_list[1] then
		log_item_once("no_ammo_list", sec, string.format("%s: no ammo list (ammo_class=%s)", sec, ammo_class))
		return nil
	end

	local rounds = {}
	local seen = {}

	for _, ammo_sec in ipairs(ammo_list) do
		if ammo_sec ~= BUCK_SELF and not seen[ammo_sec] and ini_sys:section_exist(ammo_sec)
			and not is_degraded_ammo(ammo_sec) then
			seen[ammo_sec] = true

			local k_hit = ini_sys:r_float_ex(ammo_sec, "k_hit") or 1
			local k_ap = ini_sys:r_float_ex(ammo_sec, "k_ap") or 0
			local air_res = ini_sys:r_float_ex(ammo_sec, "k_air_resistance") or 0.05
			-- Pellet count is per-round: a weapon's ammo_class can mix slugs
			-- (1 projectile) with buckshot (many), so each row must use its
			-- own round's pellet count, not the highest one seen across the
			-- whole ammo_class.
			local pellets = ini_sys:r_float_ex(ammo_sec, "buck_shot") or 0
			pellets = (pellets > 1) and pellets or 1

			rounds[#rounds + 1] = {
				sec = ammo_sec,
				label = ammo_display_label(ammo_sec),
				k_hit = k_hit,
				k_ap = k_ap,
				air_res = air_res,
				pellets = pellets,
				ap = math.floor(k_ap * AP_SCALE + 0.5),
				-- Weapon hit_power is constant per gun; sort by ammo damage contribution.
				dmg = k_hit * pellets,
			}
		end
	end

	if #rounds == 0 then
		log_item_once("no_valid_rounds", sec, string.format("%s: no usable ammo rounds (ammo_class=%s)", sec, ammo_class))
		return nil
	end

	if CONFIG.ammo_order ~= "default" then
		table.sort(rounds, function(a, b)
			if CONFIG.ammo_order == "ap" then
				if a.ap ~= b.ap then
					return a.ap > b.ap
				end
				return a.label < b.label
			end
			if a.dmg ~= b.dmg then
				return a.dmg > b.dmg
			end
			if a.ap ~= b.ap then
				return a.ap < b.ap
			end
			return a.label < b.label
		end)
	end

	if max_count and #rounds > max_count then
		local capped = {}
		for i = 1, max_count do
			capped[i] = rounds[i]
		end
		return capped
	end

	return rounds
end

local function build_ammo_damage_rows(obj, sec)
	local rounds = collect_sorted_ammo_rounds(obj, sec, #ROW_XML)
	if not rounds then
		return nil
	end

	local hit_power = gun_hit_power(obj, sec)
	if hit_power <= 0 then
		log_item_once("no_hit_power", sec, string.format("%s: hit_power<=0", sec))
		return nil
	end

	local dist = calc_range()
	local barrel = barrel_mult(obj, CONFIG.use_condition_table, "stalker")
	local silencer = silencer_mult(obj, sec)
	local rows = {}
	for _, r in ipairs(rounds) do
		local torso = fmt_tier_cells(calc_tier_damages(
			hit_power, r.k_hit, r.k_ap, r.air_res, TORSO_TIERS,
			false, dist, r.pellets, barrel, r.sec, silencer
		), NUM_TORSO_TIERS)
		local head = fmt_tier_cells(calc_tier_damages(
			hit_power, r.k_hit, r.k_ap, r.air_res, HEAD_TIERS,
			true, dist, r.pellets, barrel, r.sec, silencer
		), NUM_HEAD_TIERS)
		rows[#rows + 1] = {
			label = r.label,
			ap = r.ap,
			torso = torso,
			head = head,
		}
	end

	if #rows == 0 then
		return nil
	end

	-- Shared color scale per section: 1 (grey) .. max damage (bright red).
	local torso_hi = section_dmg_max(rows, "torso")
	local head_hi = section_dmg_max(rows, "head")
	local ordered = {}

	for _, row in ipairs(rows) do
		ordered[#ordered + 1] = {
			type = row.label,
			ap = tostring(row.ap),
			ap_val = row.ap,
			torso = row.torso,
			head = row.head,
			torso_lo = 1,
			torso_hi = torso_hi,
			head_lo = 1,
			head_hi = head_hi,
		}
	end

	return {
		rows = ordered,
		silencer = silencer,
	}
end

-- Mutant ammo_mult (default 0.85). Matches CQC monster hit rules; Pseudogiant-only
-- overrides are intentionally omitted (this row is generic flesh damage).
local MUTANT_BASE_MULT = 0.85
local MUTANT_AMMO_MULT_DEFAULT = 0.85
local MUTANT_AMMO_MULT = {
	["ammo_12x70_buck"] = 0.90,
	["ammo_12x70_buck_bad"] = 0.90,
	["ammo_20x70_buck"] = 0.90,
	["ammo_23x75_shrapnel"] = 1.00,
	["ammo_12x76_zhekan"] = 1.00,
	["ammo_12x76_zhekan_bad"] = 1.00,
	["ammo_23x75_barrikada"] = 1.00,
	["ammo_9x19_pbp"] = 1.00,
	["ammo_9x19_pbp_bad"] = 1.00,
	["ammo_9x18_pmm"] = 1.00,
	["ammo_9x18_pmm_bad"] = 1.00,
	["ammo_5.45x39_ep"] = 1.00,
	["ammo_5.45x39_ep_bad"] = 1.00,
	["ammo_5.56x45_ss190"] = 1.00,
	["ammo_5.56x45_ss190_bad"] = 1.00,
	["ammo_7.62x25_ps"] = 1.00,
	["ammo_7.62x25_ps_bad"] = 1.00,
	["ammo_7.62x25_p"] = 1.75,
	["ammo_7.62x25_p_bad"] = 1.75,
	["ammo_357_hp_mag"] = 1.00,
	["ammo_357_hp_mag_bad"] = 1.00,
	["ammo_11.43x23_hydro"] = 1.00,
	["ammo_11.43x23_hydro_bad"] = 1.00,
	["ammo_11.43x23_fmj"] = 1.00,
	["ammo_11.43x23_fmj_bad"] = 1.00,
}

local function mutant_ammo_mult(ammo_sec)
	return MUTANT_AMMO_MULT[ammo_sec] or MUTANT_AMMO_MULT_DEFAULT
end

-- Per-ammo flesh damage vs a generic mutant (species mult 100%, no weak spot).
-- Same ammo order as the damage table.
format_raw_ammo_damage_slash = function(obj, sec)
	local rounds = collect_sorted_ammo_rounds(obj, sec, nil)
	if not rounds then
		return nil
	end

	local hit_power = gun_hit_power(obj, sec)
	if hit_power <= 0 then
		return nil
	end

	local dist = calc_range()
	local barrel = barrel_mult(obj, CONFIG.use_condition_stats, "mutant")
	local diff = difficulty_mult()
	local parts = {}
	for _, r in ipairs(rounds) do
		local dmg = math.floor(
			hit_power / dist_atten(r.air_res, dist)
				* r.k_hit * r.pellets
				* MUTANT_BASE_MULT * mutant_ammo_mult(r.sec)
				* barrel * diff
				* DAMAGE_SCALE + 0.5
		)
		parts[#parts + 1] = color_ammo_value(r.label, dmg)
	end

	if #parts == 0 then
		return nil
	end
	-- Color codes wrap each value; separators stay default (not ammo-colored).
	return table.concat(parts, TYPE_CODE_DEFAULT .. " / ")
end

-- Per-ammo pre-armor stalker torso damage at calc_range() (CQC power, no AP/armor).
-- Same ammo order as the damage table.
format_stalker_ammo_damage_slash = function(obj, sec)
	local rounds = collect_sorted_ammo_rounds(obj, sec, nil)
	if not rounds then
		return nil
	end

	local hit_power = gun_hit_power(obj, sec)
	if hit_power <= 0 then
		return nil
	end

	local dist = calc_range()
	local barrel = barrel_mult(obj, CONFIG.use_condition_stats, "stalker")
	local silencer = silencer_mult(obj, sec)
	local parts = {}
	for _, r in ipairs(rounds) do
		local dmg = math.floor(
			base_power(hit_power, r.k_hit, r.air_res, dist, BONE_DMG_TORSO, 1.0, r.pellets, barrel, r.sec, silencer)
				* DAMAGE_SCALE + 0.5
		)
		parts[#parts + 1] = color_ammo_value(r.label, dmg)
	end

	if #parts == 0 then
		return nil
	end
	-- Color codes wrap each value; separators stay default (not ammo-colored).
	return table.concat(parts, TYPE_CODE_DEFAULT .. " / ")
end

local function apply_column_headers(fields)
	if not fields or not fields.col_labels then
		return
	end

	local show_raw = CONFIG.column_headers == "raw"

	if fields.grp_torso then
		fields.grp_torso:SetText("vs Torso")
	end
	if fields.grp_head then
		fields.grp_head:SetText("vs Head")
	end

	for i, tier in ipairs(TORSO_TIERS) do
		local wnd = fields.col_labels.torso[i]
		if wnd then
			wnd:SetText(show_raw and format_armor_label(tier.armor) or tier.name)
			wnd:SetTextColor(CLR.white)
		end
	end
	for i, tier in ipairs(HEAD_TIERS) do
		local wnd = fields.col_labels.head[i]
		if wnd then
			wnd:SetText(show_raw and format_armor_label(tier.armor) or tier.name)
			wnd:SetTextColor(CLR.white)
		end
	end
end

local function set_damage_cell(wnd, cell, lo, hi)
	if not wnd then
		return
	end
	if cell then
		wnd:SetText(cell.text)
		wnd:SetTextColor(dmg_value_color(cell.dmg, lo, hi))
	else
		wnd:SetText("")
		wnd:SetTextColor(CLR.value)
	end
end

local function hide_damage_panel(info)
	if not info.dorn_wpn_damage then
		return
	end

	local fields = info.dorn_wpn_fields
	if fields then
		for _, row in ipairs(fields.rows) do
			row.base:Show(false)
		end
	end

	info.dorn_wpn_damage:Show(false)
end

-- Child fields are attached to their row's own base static, so their XML y is
-- relative to the row (not the panel). Otherwise every row would draw at the
-- same y and stack on top of each other. Only the dynamic number cells are kept
-- as refs; static text lives in the XML and just needs to exist.
local function init_row_fields(xml, dlg, row_path)
	local base = xml:InitStatic(row_path, dlg)
	local row = {
		base = base,
		type = xml:InitTextWnd(row_path .. ":type", base),
		ap = xml:InitTextWnd(row_path .. ":ap", base),
		torso = {},
		head = {},
	}
	for i = 1, NUM_TORSO_TIERS do
		row.torso[i] = xml:InitTextWnd(row_path .. ":t" .. i, base)
	end
	for i = 1, NUM_HEAD_TIERS do
		row.head[i] = xml:InitTextWnd(row_path .. ":h" .. i, base)
	end
	return row
end

local COL_HDR_2 = { "type", "ap" }
for i = 1, NUM_TORSO_TIERS do
	COL_HDR_2[#COL_HDR_2 + 1] = "t" .. i
end
for i = 1, NUM_HEAD_TIERS do
	COL_HDR_2[#COL_HDR_2 + 1] = "h" .. i
end

-- Read row pitch from the XML positions set at init (row_1/row_2). Panel height
-- ends flush with the last visible data row.
local function read_layout_metrics(fields)
	local row1 = fields.rows[1].base
	local row2 = fields.rows[2].base

	local data_top_y = row1:GetWndPos().y
	local row_step = row2:GetWndPos().y - data_top_y
	local row_h = row1:GetHeight()

	return {
		data_top_y = data_top_y,
		row_step = row_step,
		row_h = row_h,
	}
end

local function create_damage_fields(parent, panel_x)
	local ok, dlg = pcall(function()
		return DAMAGE_XML:InitStatic("panel", parent)
	end)
	if not ok or not dlg then
		log_once("panel_xml_fail", "create_damage_fields: ui_dorn_weapon_tooltip.xml init failed")
		return nil, nil
	end

	if panel_x ~= nil then
		local pos = dlg:GetWndPos()
		dlg:SetWndPos(vector2():set(panel_x, pos.y))
	end

	local header = DAMAGE_XML:InitStatic("panel:header", dlg)
	local col_hdr_2 = DAMAGE_XML:InitStatic("panel:col_hdr_2", dlg)

	DAMAGE_XML:InitTextWnd("panel:header:title", header)
	local grp_torso = DAMAGE_XML:InitTextWnd("panel:header:grp_torso", header)
	local grp_head = DAMAGE_XML:InitTextWnd("panel:header:grp_head", header)
	DAMAGE_XML:InitStatic("panel:sep", dlg)

	local col_labels = { torso = {}, head = {} }
	for _, name in ipairs(COL_HDR_2) do
		if name:match("^t%d") then
			col_labels.torso[tonumber(name:sub(2))] = DAMAGE_XML:InitTextWnd("panel:col_hdr_2:" .. name, col_hdr_2)
		elseif name:match("^h%d") then
			col_labels.head[tonumber(name:sub(2))] = DAMAGE_XML:InitTextWnd("panel:col_hdr_2:" .. name, col_hdr_2)
		else
			DAMAGE_XML:InitTextWnd("panel:col_hdr_2:" .. name, col_hdr_2)
		end
	end

	local fields = {
		dlg = dlg,
		header = header,
		col_hdr_2 = col_hdr_2,
		grp_torso = grp_torso,
		grp_head = grp_head,
		col_labels = col_labels,
		rows = {},
	}

	for i, row_path in ipairs(ROW_XML) do
		local row = init_row_fields(DAMAGE_XML, dlg, row_path)
		row.base:Show(false)
		fields.rows[i] = row
	end

	fields.layout = read_layout_metrics(fields)
	apply_column_headers(fields)

	return dlg, fields
end

-- panel_width: optional fixed width (details scroll); default uses parent/desc width.
local function populate_damage_fields(fields, data, panel_width)
	if not fields or not fields.dlg or not data then
		return false
	end

	local layout = fields.layout
	if not layout then
		return false
	end

	apply_column_headers(fields)

	local any_row = false
	local row_y = layout.data_top_y
	local last_row_y = layout.data_top_y
	for i, row in ipairs(fields.rows) do
		local rd = data.rows[i]
		if rd then
			row.type:SetText(rd.type or "")
			row.type:SetTextColor(ammo_type_color(rd.type))
			row.ap:SetText(rd.ap or "")
			row.ap:SetTextColor(ap_display_color(rd.ap_val or 0, data.silencer))
			for t = 1, NUM_TORSO_TIERS do
				set_damage_cell(row.torso[t], rd.torso and rd.torso[t], rd.torso_lo, rd.torso_hi)
			end
			for h = 1, NUM_HEAD_TIERS do
				set_damage_cell(row.head[h], rd.head and rd.head[h], rd.head_lo, rd.head_hi)
			end
			row.base:SetWndPos(vector2():set(0, row_y))
			row.base:Show(true)
			last_row_y = row_y
			row_y = row_y + layout.row_step
			any_row = true
		else
			row.base:Show(false)
		end
	end

	if not any_row then
		fields.dlg:Show(false)
		return false
	end

	local w = panel_width or fields.dlg:GetWidth()
	local panel_h = last_row_y + layout.row_h
	fields.dlg:SetWndSize(vector2():set(w, panel_h))
	fields.dlg:Show(true)
	return true
end

local DETAILS_PANEL_WIDTH = 500

local function add_details_damage_section(sheet, obj)
	if not CONFIG.show_damage_table or not sheet or not sheet.scroll or not sheet.xml then
		return
	end

	local sec = ini_sys:r_string_ex(obj:section(), "parent_section") or obj:section()
	-- IsWeapon(sec) crashes on section strings; use ammo_class like GetType.
	if not ini_sys:r_string_ex(sec, "ammo_class") or IsItem("fake_ammo_wpn", sec) then
		return
	end

	local damage_data = build_ammo_damage_rows(obj, sec)
	if not damage_data then
		return
	end

	local xml = sheet.xml
	local _st = xml:InitStatic("itm_details:form", nil)
	local dlg, fields = create_damage_fields(_st, 3)
	if not dlg or not populate_damage_fields(fields, damage_data, DETAILS_PANEL_WIDTH) then
		log_item_once("details_fail", sec, string.format("%s: details damage section failed", sec))
		return
	end

	log_item_once("details_ok", sec, string.format("%s: details damage section shown (%d rows)", sec, #damage_data.rows))

	utils_xml.sync_size(dlg, _st, 0, 0)
	sheet.scroll:AddWindow(_st, true)
	_st:SetAutoDelete(true)
end

-- Reposition replacement-parts block (Parts in Tooltip mod) after we shift stats/ammo.
local function sync_parts_layout(info, tail)
	if not info.parts or not info.parts:IsShown() then
		return tail
	end

	local stats = info.stats_dialog
	local stats_x = stats and stats:GetWndPos().x or 0
	local parts_x = info.parts:GetWndPos().x
	local vertical = stats and parts_x > stats_x + 50

	if vertical then
		local stats_pos = stats:GetWndPos()
		local parts_pos = info.parts:GetWndPos()
		info.parts:SetWndPos(vector2():set(parts_pos.x, stats_pos.y))
		if info.SyncPartsText then
			info:SyncPartsText(true)
		end
		local parts_bottom = stats_pos.y + info.parts:GetHeight()
		local tail_bottom = tail:GetWndPos().y + tail:GetHeight()
		if parts_bottom > tail_bottom then
			tail = info.parts
		end
	else
		info:Sync_Y(tail, info.parts, SECTION_GAP)
		tail = info.parts
		if info.SyncPartsText then
			info:SyncPartsText()
		end
	end

	return tail
end

local function sync_damage_layout(info)
	local tail = info.desc

	if CONFIG.show_damage_table and info.dorn_wpn_damage and info.dorn_wpn_damage:IsShown() then
		info:Sync_Y(info.desc, info.dorn_wpn_damage, PANEL_TOP_OFFSET)
		tail = info.dorn_wpn_damage
	end

	if info.stats_dialog:IsShown() then
		info:Sync_Y(tail, info.stats_dialog, BOTTOM_OFFSET)
		tail = info.stats_dialog
	end

	if info.ammo and info.ammo:IsShown() then
		info:Sync_Y(tail, info.ammo, SECTION_GAP)
		tail = info.ammo
	end

	tail = sync_parts_layout(info, tail)

	info:Sync_H(tail, info.frame, SECTION_GAP)
end

local function refresh_weapon_damage_panel(info, obj, sec)
	if not info then
		return
	end
	if not info.dorn_wpn_damage then
		log_once("no_panel", "tooltip missing damage panel (create_damage_fields failed at init?)")
		return
	end

	hide_damage_panel(info)

	if not CONFIG.show_damage_table then
		log_once("table_disabled", "show_damage_table is off in MCM")
		sync_damage_layout(info)
		return
	end

	if not info:IsShown() then
		return
	end

	sec = sec or (obj and obj:section())
	if not sec or info:GetType(sec) ~= "weapon" then
		return
	end

	log_once("update_hook", "UIInfoItem Update hook reached for a weapon tooltip")

	local damage_data = build_ammo_damage_rows(obj, sec)
	if not damage_data then
		return
	end

	local fields = info.dorn_wpn_fields
	if fields then
		local w = info.desc and info.desc:GetWidth()
		if not populate_damage_fields(fields, damage_data, w) then
			log_item_once("populate_fail", sec, string.format("%s: populate_damage_fields failed", sec))
			info.dorn_wpn_damage:Show(false)
			return
		end
		log_item_once("panel_ok", sec, string.format("%s: hover damage panel shown (%d rows)", sec, #damage_data.rows))
	end
	sync_damage_layout(info)
end

-- The details/workshop sheets build stats via utils_ui.get_stats_xml, which
-- paints the value grey (clr_list p1) and never exposes the created text window
-- for later recolor (unlike the hover tooltip's reused stat boxes). So for our
-- Dorn rows we rebuild the box ourselves with white text; everything else
-- falls through to the stock implementation.
local base_get_stats_xml

local DORN_WHITE_STAT_NAMES = {
	["ui_dorn_wpn_hit_power"] = true,
	["ui_dorn_wpn_stalker_damage"] = true,
	["ui_dorn_wpn_ammo_torso"] = true,
	["ui_dorn_wpn_base_spread"] = true,
	["ui_dorn_wpn_movement_spread"] = true,
	["ui_dorn_wpn_weapon_wear"] = true,
	["ui_dorn_wpn_burst_control"] = true,
	["ui_dorn_wpn_bullet_drop"] = true,
}

local function build_white_stat_xml(handler, obj, sec, gr, stat)
	local value, nclr

	if gr.name == "ui_dorn_wpn_ammo_torso" then
		value = format_raw_ammo_damage_slash(obj, sec)
		nclr = false
	elseif gr.name == "ui_dorn_wpn_stalker_damage" then
		value = format_stalker_ammo_damage_slash(obj, sec)
		nclr = false
	elseif gr.name == "ui_dorn_wpn_hit_power" then
		value, nclr = utils_ui.get_stats_string_value(obj, sec, gr, stat)
	elseif dorn_weapon_tooltip_stats and dorn_weapon_tooltip_stats.text_for_name then
		value = dorn_weapon_tooltip_stats.text_for_name(gr.name, obj, sec)
		nclr = false
	else
		value, nclr = utils_ui.get_stats_string_value(obj, sec, gr, stat)
	end

	if not value then
		return
	end

	local st = STAT_XML:InitStatic("item_info:stats_box", handler)

	local st_icon = STAT_XML:InitStatic("item_info:stats_box:icon", st)
	st_icon:InitTexture(gr.icon_p)

	-- Only the label is whitened; the value keeps the stock grey/red like every
	-- other stat on the sheet.
	local st_cap = STAT_XML:InitTextWnd("item_info:stats_box:cap", st)
	st_cap:SetText(game.translate_string(gr.name))
	st_cap:SetTextColor(CLR.white)

	local st_txt = STAT_XML:InitTextWnd("item_info:stats_box:prog_txt", st)
	if gr.name == "ui_dorn_wpn_ammo_torso" or gr.name == "ui_dorn_wpn_stalker_damage" then
		st_txt:SetTextComplexMode(true)
	end
	st_txt:SetText(value)
	st_txt:SetTextColor(nclr and CLR.stat_neg or CLR.stat_pos)

	st:SetAutoDelete(true)
	return st
end

local function get_stats_xml_hook(handler, obj, sec, gr, stat)
	local grp = gr
	if type(grp) == "string" then
		grp = utils_ui.stats_table and utils_ui.stats_table[grp]
	end

	if grp and not grp.track and grp.name and DORN_WHITE_STAT_NAMES[grp.name] then
		local ok, st = pcall(build_white_stat_xml, handler, obj, sec, grp, stat)
		if ok and st then
			return st
		end
	end

	return base_get_stats_xml(handler, obj, sec, gr, stat)
end

local base_itm_details_reset
local base_itm_details_addtext

local function itm_details_addtext_hook(self, xml, path, offset, txt)
	local ele = base_itm_details_addtext(self, xml, path, offset, txt)

	-- Vanilla adds the item description as the first text_s_l row (after weight).
	if self.dorn_details_pending and path == "text_s_l" then
		local obj = self.dorn_details_pending
		self.dorn_details_pending = nil
		add_details_damage_section(self, obj)
	end

	return ele
end

local function itm_details_reset_hook(self, obj)
	if obj and CONFIG.show_damage_table then
		local sec = ini_sys:r_string_ex(obj:section(), "parent_section") or obj:section()
		if ini_sys:r_string_ex(sec, "ammo_class") and not IsItem("fake_ammo_wpn", sec) then
			self.dorn_details_pending = obj
		end
	end

	if base_itm_details_reset then
		base_itm_details_reset(self, obj)
	end

	self.dorn_details_pending = nil
end

local details_hook_ok = false

-- Vanilla/Sota UIInfoItem only pre-creates 16 stat rows. Full Dorn + Momopate
-- can exceed that (max_range + 5 companions + 3 damage); expand once at init.
local STAT_SLOT_TARGET = 24

local function ensure_stat_slots(info)
	if not info or not info.stats or not info.stats_dialog then
		return
	end
	local n = #info.stats
	if n >= STAT_SLOT_TARGET then
		return
	end
	for i = n + 1, STAT_SLOT_TARGET do
		local slot = {}
		slot.base = STAT_XML:InitStatic("item_info:stats_box", info.stats_dialog)
		slot.icon = STAT_XML:InitStatic("item_info:stats_box:icon", slot.base)
		slot.cap = STAT_XML:InitTextWnd("item_info:stats_box:cap", slot.base)
		slot.bar2 = STAT_XML:InitProgressBar("item_info:stats_box:prog_bar", slot.base)
		slot.bar1 = STAT_XML:InitProgressBar("item_info:stats_box:prog_bar", slot.base)
		slot.txt = STAT_XML:InitTextWnd("item_info:stats_box:prog_txt", slot.base)
		slot.comp = STAT_XML:InitTextWnd("item_info:stats_box:compare", slot.base)
		slot.base:Show(false)
		info.stats[i] = slot
	end
end

local function install_details_hook()
	if not ui_itm_details or not ui_itm_details.UIItemSheet then
		log_once("hooks_details_missing", "details hook skipped: ui_itm_details.UIItemSheet missing")
		return
	end

	if not base_itm_details_reset then
		base_itm_details_reset = ui_itm_details.UIItemSheet.Reset
		ui_itm_details.UIItemSheet.Reset = itm_details_reset_hook
	end

	if not base_itm_details_addtext then
		base_itm_details_addtext = ui_itm_details.UIItemSheet.AddText
		ui_itm_details.UIItemSheet.AddText = itm_details_addtext_hook
	end

	if not base_get_stats_xml and utils_ui.get_stats_xml then
		base_get_stats_xml = utils_ui.get_stats_xml
		utils_ui.get_stats_xml = get_stats_xml_hook
	end

	details_hook_ok = true
end

local function uiinfo_init_hook(self, owner, delay)
	base_uiinfo_init(self, owner, delay)

	tracked_infos[self] = true
	ensure_stat_slots(self)

	if self.dorn_wpn_damage then
		return
	end

	local dlg, fields = create_damage_fields(self.dialog)
	if dlg then
		self.dorn_wpn_damage = dlg
		self.dorn_wpn_fields = fields
		dlg:Show(false)
		log_once("panel_init", "damage panel widgets created on tooltip init")
	else
		log_once("panel_init_fail", "damage panel widgets failed to create on tooltip init")
	end
end

local function uiinfo_update_hook(self, obj, sec, flags)
	local same_item = (obj and self.id and obj:id() == self.id)
		or (not obj and sec and self.section == sec)

	base_uiinfo_update(self, obj, sec, flags)

	if not same_item then
		apply_custom_stat_display(self, obj, sec)
		refresh_weapon_damage_panel(self, obj, sec)
	end
end

local ui_hooks_ok = false

local function install_ui_hooks()
	if not utils_ui or not utils_ui.UIInfoItem then
		log_once("hooks_ui_missing", "UI hook skipped: utils_ui.UIInfoItem missing")
		return false
	end

	if not base_uiinfo_init then
		base_uiinfo_init = utils_ui.UIInfoItem.__init
		utils_ui.UIInfoItem.__init = uiinfo_init_hook
	end

	if not base_uiinfo_update then
		base_uiinfo_update = utils_ui.UIInfoItem.Update
		utils_ui.UIInfoItem.Update = uiinfo_update_hook
	end

	ui_hooks_ok = true
	return true
end

local function on_console_execute(cmd)
	if cmd == "g_game_difficulty" then
		apply_enhanced_weapon_stats()
		for info in pairs(tracked_infos) do
			info.id = nil
			info.section = nil
		end
	end
end

-- ADV/Sota replace utils_ui.stats_table.weapon on difficulty change; re-apply
-- Dorn rows whenever their override runs so companions/placement survive.
local function hook_stats_table_override()
	if not ish_item_stats or not ish_item_stats.override_stats_table then
		return
	end
	if ish_item_stats.dorn_weapon_tooltip_wrapped then
		return
	end
	local prev = ish_item_stats.override_stats_table
	ish_item_stats.override_stats_table = function()
		prev()
		apply_enhanced_weapon_stats()
		for info in pairs(tracked_infos) do
			info.id = nil
			info.section = nil
		end
	end
	ish_item_stats.dorn_weapon_tooltip_wrapped = true
end

-- Crosshair rangefinder (Development MCM). Casts along camera look; ignores actor.
-- Flags 3 = static + objects (same as cover-tilt / xcombat rqtBoth).
local RANGEFINDER_MAX_M = 2000
local rangefinder_pick = nil

local function crosshair_range_m()
	local d = device()
	if not d or not d.cam_pos or not d.cam_dir then
		return nil
	end
	if not rangefinder_pick then
		rangefinder_pick = ray_pick()
	end
	local pick = rangefinder_pick
	pick:set_flags(3)
	pick:set_position(vector():set(d.cam_pos))
	pick:set_direction(vector():set(d.cam_dir))
	pick:set_range(RANGEFINDER_MAX_M)
	if db and db.actor then
		pick:set_ignore_object(db.actor)
	end
	if not pick:query() then
		return nil
	end
	local dist = pick:get_distance()
	if not dist or dist <= 0 then
		return nil
	end
	return dist
end

local function on_actor_update()
	if not CONFIG.rangefinder then
		return
	end
	if not (DORN and DORN.dbg and DORN.dbg.overlay) then
		return
	end
	local dist = crosshair_range_m()
	local msg
	if dist then
		if dist < 10 then
			msg = string.format("Range  %.1fm", dist)
		else
			msg = string.format("Range  %.0fm", dist)
		end
	else
		msg = string.format("Range  >%dm", RANGEFINDER_MAX_M)
	end
	DORN.dbg.overlay(MOD_ID, 1, msg, "cyan")
end

function on_game_start()
	local loader = _G[DORN_COMMON_VERSION]
	if loader then
		DORN = loader.load(MOD_ID)
	else
		printf("[DORN][%s] common loader missing (%s)", MOD_ID, DORN_COMMON_VERSION)
	end

	on_option_change()
	install_ui_hooks()
	install_details_hook()
	hook_stats_table_override()

	RegisterScriptCallback("on_console_execute", on_console_execute)
	RegisterScriptCallback("on_option_change", on_option_change)
	RegisterScriptCallback("actor_on_update", on_actor_update)

	log_once("startup", string.format(
		"loaded: dorn=%s, ui_hooks=%s, details_hook=%s, table=%s, hit=%s, mutant=%s, place=%s, stats_mod=%s",
		tostring(DORN ~= nil), tostring(ui_hooks_ok), tostring(details_hook_ok),
		tostring(CONFIG.show_damage_table), tostring(CONFIG.show_hit_power),
		tostring(CONFIG.show_mutant_damage), tostring(CONFIG.stat_row_placement),
		tostring(dorn_weapon_tooltip_stats and dorn_weapon_tooltip_stats.NAME ~= nil)))
end
