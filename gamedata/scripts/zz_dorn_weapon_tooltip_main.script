local DAMAGE_SCALE = 100

local BUCK_SELF = "ammo_12x70_buck_self"

-- k_ap is the raw armor-piercing coefficient. The ammo's own info card scales it
-- x1000 (k_ap 0.01 -> "10"), so we match that here.
-- Displayed AP = k_ap * AP_SCALE. Color scale: grey at 0 → full orange at the
-- display AP needed to penetrate 0.650 torso bone armor (Max column) at calc_range.
local AP_SCALE = 1000
local AP_COLOR_ARMOR = 0.650
local AP_COLOR_AP_SCALE = 0.7000 -- Max-tier outfit ap_scale average
local AP_COLOR_REF_AIR = 0.05
local REF_DIST_M = 20

