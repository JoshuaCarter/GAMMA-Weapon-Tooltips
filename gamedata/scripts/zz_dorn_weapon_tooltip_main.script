	{ armor = 0.000, ap_scale = 0.8096, hit_frac = 0,      name = "Min" },
	{ armor = 0.150, ap_scale = 0.7571, hit_frac = 0.4071, name = "Lgt" },
	{ armor = 0.200, ap_scale = 0.7861, hit_frac = 0.4389, name = "Mid" },
	{ armor = 0.300, ap_scale = 0.7621, hit_frac = 0.3431, name = "Hvy" },
