local NUM_TORSO_TIERS = #TORSO_TIERS
local NUM_HEAD_TIERS = #HEAD_TIERS

-- Live combat math follows CQC grok_bo (higher load order than GBOOBS):
-- combat AP = ini k_ap x10 x ap_scale x barrel / range_factor x 0.80 x difficulty
--   x silencer (1.07 when equipped / integrated, if MCM apply_silencer).
-- Bone mults from CQC stalker_damage. Difficulty from CQC/GAMMA diff_game type.
-- Sniper +0.05 AP omitted (generic tooltip). Mutant path has no silencer in CQC.
local BONE_DMG_TORSO = 0.9    -- bip01_spine
local BONE_DMG_HEAD  = 3.65   -- bip01_head
local BALLISTIC_BONUS = 1.1
local K_AP_COMBAT_SCALE = 10  -- CQC: ini k_ap * 10 for combat
local AP_TAIL = 0.80          -- CQC post-grouping AP adjustment
local SILENCER_BOOST = 1.07
-- CQC integrated_silencer table (parent_section keys).
local INTEGRATED_SILENCER = {
	["wpn_dvl10_m1"] = true,
	["wpn_vssk"] = true,
	["wpn_val_tac"] = true,
	["wpn_vintorez"] = true,
	["wpn_val"] = true,
	["wpn_val_modern"] = true,
	["wpn_vintorez_m1"] = true,
	["wpn_vintorez_m2"] = true,
	["wpn_vintorez_isg"] = true,
	["wpn_mp5sd"] = true,
	["wpn_mp5sd_custom"] = true,
	["wpn_mp5sd_new"] = true,
}
local DIFFICULTY_MULT = {
	[1] = 1.3,
	[2] = 1.05,
	[3] = 0.90,
	[4] = 0.80,
}
-- CQC head AP bonuses apply to eyes/eyelid/jaw/neck, not bip01_head.
-- Our "vs Head" columns model bip01_head, so no AP boost.

local function clamp(v, lo, hi)
	if v < lo then
		return lo
	end
	if v > hi then
		return hi
	end
	return v
end

local function lerp(a, b, t)
	return a + (b - a) * t
end

-- Damage cells fade grey (least damage) to red (most damage). Scaled 1..max
-- across all rows in a section (torso or head) so identical numbers always
-- share the same color and higher damage is always brighter than lower.
-- Head uses its own max (headshots hit much harder than torso).
-- gamma < 1 brightens the mid-range so the ramp reads as a smooth gradient.
local DMG_COLOR_GAMMA = 0.75
local DMG_CLR_MIN = { 135, 135, 135 }
local DMG_CLR_MAX = { 255, 64, 64 }
local function dmg_value_color(dmg, lo, hi)
	local span = hi - lo
	local t = (span > 0) and clamp((dmg - lo) / span, 0, 1) or 1
	t = t ^ DMG_COLOR_GAMMA
	return GetARGB(255,
		math.floor(lerp(DMG_CLR_MIN[1], DMG_CLR_MAX[1], t)),
		math.floor(lerp(DMG_CLR_MIN[2], DMG_CLR_MAX[2], t)),
		math.floor(lerp(DMG_CLR_MIN[3], DMG_CLR_MAX[3], t)))
end

-- Column header label: raw bone armor float (same value used in pen check).
local function format_armor_label(armor)
	if armor == 0 then
		return "0"
	end
	local s = string.format("%.3f", armor)
	return (s:gsub("0+$", ""):gsub("%.$", ""))
end

