}

local function ammo_display_label(sec)
	local base = sec or ""
	if base:sub(-8) == "_verybad" then
		base = base:sub(1, -9)
	elseif base:sub(-4) == "_bad" then
		base = base:sub(1, -5)
	end
	return AMMO_TYPE_SHORT[base] or AMMO_TYPE_UNKNOWN
end

local function ammo_type_color(label)
	local name = AMMO_TYPE_COLOR[label]
	return (name and TYPE_ARGB[name]) or TYPE_ARGB.grey
end

local function ammo_type_color_code(label)
	local name = AMMO_TYPE_COLOR[label]
	return (name and TYPE_CODE[name]) or TYPE_CODE.grey
end

local function color_ammo_value(label, text)
	return ammo_type_color_code(label) .. tostring(text)
end

local CLR = {
	white = GetARGB(255, 255, 255, 255),
	value = GetARGB(255, 175, 175, 175),
	-- Match utils_ui clr_list p1/n1 (stock stat value colors).
	stat_pos = GetARGB(255, 170, 170, 170),
	stat_neg = GetARGB(255, 200, 50, 50),
}

-- Forward-declared here so the display helpers below capture these as upvalues.
local format_raw_ammo_damage_slash
local format_stalker_ammo_damage_slash

local ENHANCED_STAT_LABELS = {}

local function refresh_enhanced_stat_labels()
	ENHANCED_STAT_LABELS = {
		hit_power = game.translate_string("ui_dorn_wpn_hit_power"),
		stalker_damage = game.translate_string("ui_dorn_wpn_stalker_damage"),
		ammo_damage = game.translate_string("ui_dorn_wpn_ammo_torso"),
		base_spread = game.translate_string("ui_dorn_wpn_base_spread"),
		movement_spread = game.translate_string("ui_dorn_wpn_movement_spread"),
		weapon_wear = game.translate_string("ui_dorn_wpn_weapon_wear"),
		burst_control = game.translate_string("ui_dorn_wpn_burst_control"),
		bullet_drop = game.translate_string("ui_dorn_wpn_bullet_drop"),
	}
end

local function dorn_custom_stat_text(cap, obj, sec)
	if not cap then
		return nil
	end
	if CONFIG.show_stalker_damage and cap == ENHANCED_STAT_LABELS.stalker_damage then
		local v = format_stalker_ammo_damage_slash(obj, sec)
		if DORN and DORN.dbg and DORN.dbg.log then
			DORN.dbg.log(MOD_ID, string.format("stalker_dmg [%s]: %s", tostring(sec), tostring(v)))
		end
		return v
	end
	if CONFIG.show_mutant_damage and cap == ENHANCED_STAT_LABELS.ammo_damage then
		local v = format_raw_ammo_damage_slash(obj, sec)
		if DORN and DORN.dbg and DORN.dbg.log then
			DORN.dbg.log(MOD_ID, string.format("mutant_dmg [%s]: %s", tostring(sec), tostring(v)))
		end
		return v
	end
	if not dorn_weapon_tooltip_stats or not dorn_weapon_tooltip_stats.text_for_name then
		if DORN and DORN.dbg and DORN.dbg.log then
			DORN.dbg.log(MOD_ID, string.format("companion stats unavailable [%s]", tostring(sec)))
		end
		return nil
	end
	local S = dorn_weapon_tooltip_stats
	local N = S.NAME
	if CONFIG.show_base_spread and cap == ENHANCED_STAT_LABELS.base_spread then
		return S.text_for_name(N.base_spread, obj, sec)
	end
	if CONFIG.show_movement_spread and cap == ENHANCED_STAT_LABELS.movement_spread then
		return S.text_for_name(N.movement_spread, obj, sec)
	end
	if CONFIG.show_weapon_wear and cap == ENHANCED_STAT_LABELS.weapon_wear then
		return S.text_for_name(N.weapon_wear, obj, sec)
	end
	if CONFIG.show_burst_control and cap == ENHANCED_STAT_LABELS.burst_control then
		return S.text_for_name(N.burst_control, obj, sec)
	end
	if CONFIG.show_bullet_drop and cap == ENHANCED_STAT_LABELS.bullet_drop then
		return S.text_for_name(N.bullet_drop, obj, sec)
	end
	return nil
end

local function apply_custom_stat_display(info, obj, sec)
	if not info or not info.stats then
		return
	end
	if (not sec or sec == "") and obj then
		local ok, section = pcall(function()
			return obj:section()
		end)
		if ok and section then
			sec = ini_sys:r_string_ex(section, "parent_section") or section
		end
	end
	-- Match GetType("weapon"): IsWeapon(sec) crashes — it calls :clsid() on the string.
	if not sec or info:GetType(sec) ~= "weapon" then
		return
	end

	for _, ele in pairs(info.stats) do
		if ele.cap and ele.txt then
			local cap = ele.cap:GetText()
			if cap then
				if CONFIG.show_hit_power and cap == ENHANCED_STAT_LABELS.hit_power then
					ele.cap:SetTextColor(CLR.white)
					ele.txt:SetTextColor(CLR.white)
				else
					local custom = dorn_custom_stat_text(cap, obj, sec)
					if custom then
						ele.cap:SetTextColor(CLR.white)
						if cap == ENHANCED_STAT_LABELS.stalker_damage
							or cap == ENHANCED_STAT_LABELS.ammo_damage then
							ele.txt:SetTextComplexMode(true)
						end
						ele.txt:SetText(custom)
						ele.txt:Show(true)
						ele.txt:SetTextColor(CLR.white)
					end
				end
			end
		end
	end
end

