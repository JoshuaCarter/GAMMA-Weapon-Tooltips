	show_weapon_wear = true,
	show_burst_control = true,
	show_bullet_drop = true,
	stat_row_placement = "inline",
	column_headers = "names",
	ammo_order = "default",
	calc_range_m = 20,
	use_condition_table = false,
	use_condition_stats = false,
	apply_silencer = true,
	debug_log = false,
	rangefinder = false,
}

