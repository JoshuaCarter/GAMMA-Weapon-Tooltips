	{ armor = 0.400, ap_scale = 0.7500, hit_frac = 0.2000, name = "Hvy+" },
	{ armor = 0.550, ap_scale = 0.7000, hit_frac = 0.1500, name = "Exo" },
	{ armor = 0.650, ap_scale = 0.7000, hit_frac = 0.1500, name = "Max" },
}
local HEAD_TIERS = {
