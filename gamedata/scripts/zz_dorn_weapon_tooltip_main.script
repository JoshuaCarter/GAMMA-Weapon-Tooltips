-- Type-column colors by short label (ammo_type_label_reference.md Color column).
-- Lookup by label; unknown / ???? fall back to grey.
-- RGB matches color_defs.xml where names overlap; teal ≈ d_cyan.
local TYPE_RGB = {
	yellow = { 255, 255, 0 },
	orange = { 255, 150, 0 },
	teal = { 64, 200, 180 },
	grey = { 170, 170, 170 },
}
local TYPE_ARGB = {}
local TYPE_CODE = {}
for name, rgb in pairs(TYPE_RGB) do
	TYPE_ARGB[name] = GetARGB(255, rgb[1], rgb[2], rgb[3])
	TYPE_CODE[name] = string.format("%%c[255,%d,%d,%d]", rgb[1], rgb[2], rgb[3])
end
local TYPE_CODE_DEFAULT = "%c[default]"
local AMMO_TYPE_COLOR = {
	-- yellow
	["FMJ"] = "yellow",
	["BULL"] = "yellow",
	["SLUG"] = "yellow",
	["LRNPC"] = "yellow",
	["7N1"] = "yellow",
	["SP10"] = "yellow",
	["SP-5"] = "yellow",
	["PP"] = "yellow",
	-- teal
	["HP"] = "teal",
	["BUCK"] = "teal",
	["SHRAP"] = "teal",
	["FED"] = "teal",
	-- orange
	["AP"] = "orange",
	["SLAP"] = "orange",
	["BARR"] = "orange",
